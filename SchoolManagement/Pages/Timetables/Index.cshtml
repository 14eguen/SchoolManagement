@page
@model SchoolManagement.Pages_Timetables.IndexModel

@{
    ViewData["Title"] = "Quản lý Thời khóa biểu";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0 text-gray-800"><i class="fa-solid fa-calendar-days me-2 text-primary"></i>Danh sách Thời khóa biểu</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-page="Create" class="btn btn-primary shadow-sm"><i class="fa-solid fa-plus me-1"></i>Thêm Mới</a>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
        <form method="get" class="d-flex w-50">
            <div class="input-group">
                <input asp-for="SearchString" class="form-control" placeholder="Tìm kiếm theo Lớp, Môn, Giáo viên..." aria-label="Search" />
                <button class="btn btn-outline-secondary" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
        </form>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Học kỳ</th>
                        <th>Lớp học</th>
                        <th>Môn học</th>
                        <th>Giáo viên</th>
                        <th>Thứ</th>
                        <th>Tiết</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Timetables != null && Model.Timetables.Any())
                    {
                        foreach (var item in Model.Timetables)
                        {
                            <tr>
                                <td>@item.Semester</td>
                                <td class="fw-semibold text-primary">@item.Class?.Name</td>
                                <td><span class="badge bg-info text-dark">@item.Subject?.Name</span></td>
                                <td>@item.Teacher?.FullName</td>
                                <td>@item.DayOfWeek</td>
                                <td>@item.Period</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                                        {
                                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Sửa"><i class="fa-solid fa-pen-to-square"></i></a>
                                        }
                                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                                        {
                                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Xóa"><i class="fa-solid fa-trash-can"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Không tìm thấy dữ liệu.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination-container mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-end mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-SearchString="@Model.SearchString">Trước</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link" asp-page="./Index" asp-route-currentPage="@i" asp-route-SearchString="@Model.SearchString">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-SearchString="@Model.SearchString">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
