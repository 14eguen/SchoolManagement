<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Học Sinh</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* === STUDENT LAYOUT — PURPLE THEME === */
        #sidebar-wrapper {
            background: linear-gradient(180deg, #4a148c 0%, #6a1b9a 60%, #7b1fa2 100%) !important;
            border-right: none !important;
        }
        .sidebar-heading {
            color: #fff !important;
            border-bottom: 1px solid rgba(255,255,255,0.12);
            padding-bottom: 1rem !important;
        }
        .sidebar-section-title {
            color: rgba(255,255,255,0.45);
            font-size: 0.7rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            font-weight: 700;
            padding: 0.75rem 1rem 0.25rem;
        }
        .sidebar-nav-link {
            color: rgba(255,255,255,0.78) !important;
            border-radius: 0.5rem !important;
            margin-bottom: 2px;
            font-weight: 500;
            transition: all 0.18s ease;
            background: transparent !important;
            border: none !important;
            padding: 0.6rem 1rem;
        }
        .sidebar-nav-link:hover {
            color: #fff !important;
            background: rgba(255,255,255,0.13) !important;
        }
        .sidebar-nav-link.active {
            color: #fff !important;
            background: rgba(255,255,255,0.2) !important;
            font-weight: 600;
        }
        #page-content-wrapper { background-color: #f5f0fa; }
        .top-navbar { background: #fff !important; border-bottom: 1px solid #e0d4f0 !important; }
        .role-badge-student {
            background: linear-gradient(135deg, #6a1b9a, #4a148c);
            color: white;
            font-size: 0.7rem;
            padding: 3px 10px;
            border-radius: 99px;
            font-weight: 700;
            letter-spacing: 0.05em;
        }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Student Sidebar -->
        <div id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4">
                <div style="font-size:1.5rem; font-weight:700; color:#fff;">
                    <i class="fa-solid fa-user-graduate me-2" style="color:#ce93d8;"></i>SchoolMgr
                </div>
                <div style="font-size:0.7rem; color:rgba(255,255,255,0.5); letter-spacing:0.1em; margin-top:4px;">HỌC SINH</div>
            </div>

            <div class="px-2 pb-3">
                <a asp-page="/Student/Dashboard" class="list-group-item list-group-item-action sidebar-nav-link @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Student") == true ? "active" : "")">
                    <i class="fa-solid fa-house me-3"></i>Trang Chủ
                </a>

                <div class="sidebar-section-title mt-2">Học tập của tôi</div>
                <a asp-page="/Student/MyTimetable" class="list-group-item list-group-item-action sidebar-nav-link @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Student/MyTimetable" ? "active" : "")">
                    <i class="fa-solid fa-calendar-days me-3"></i>Thời Khóa Biểu
                </a>
                <a asp-page="/Student/MyGrades" class="list-group-item list-group-item-action sidebar-nav-link @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Student/MyGrades" ? "active" : "")">
                    <i class="fa-solid fa-chart-line me-3"></i>Kết Quả Học Tập
                </a>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar top-navbar navbar-expand-lg py-2">
                <div class="container-fluid">
                    <button class="btn btn-sm btn-light border" id="sidebarToggle">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mt-2 mt-lg-0 align-items-center gap-2">
                            <li class="nav-item">
                                <span class="role-badge-student"><i class="fa-solid fa-user-graduate me-1"></i>Học Sinh</span>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown">
                                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center me-2 fw-bold"
                                         style="width:34px;height:34px;background:linear-gradient(135deg,#4a148c,#7b1fa2);font-size:1rem;">
                                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "S")
                                    </div>
                                    <span class="fw-semibold">@(User.Identity?.Name ?? "Học sinh")</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item text-danger" asp-page="/Account/Logout">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                                    </a>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            <div class="container-fluid px-4 py-4">
                <main role="main">@RenderBody()</main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        window.addEventListener('DOMContentLoaded', event => {
            const sidebarToggle = document.body.querySelector('#sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', event => {
                    event.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                    localStorage.setItem('sb|sidebar-toggle', document.body.classList.contains('sb-sidenav-toggled'));
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
