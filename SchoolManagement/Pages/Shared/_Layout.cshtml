<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolManager</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- FontAwesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolManagement.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-white border-end" id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-primary">
                <i class="fa-solid fa-graduation-cap me-2"></i>SchoolMgr
            </div>
            <div class="list-group list-group-flush mt-3 px-2">
                <a asp-page="/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Index" ? "active" : "")"><i class="fa-solid fa-house me-3"></i>Trang Chủ</a>
                
                @if (User.IsInRole("Admin"))
                {
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-2 text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">
                      <span>Quản lý</span>
                    </h6>
                    <a asp-page="/Users/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Users") == true ? "active" : "")"><i class="fa-solid fa-users-gear me-3"></i>Người Dùng</a>
                    <a asp-page="/Teachers/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Teachers") == true ? "active" : "")"><i class="fa-solid fa-chalkboard-user me-3"></i>Giáo Viên</a>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-2 text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">
                      <span>Đào tạo</span>
                    </h6>
                    <a asp-page="/Students/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Students") == true ? "active" : "")"><i class="fa-solid fa-user-graduate me-3"></i>Học Sinh</a>
                    <a asp-page="/Classes/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Classes") == true ? "active" : "")"><i class="fa-solid fa-school me-3"></i>Lớp Học</a>
                    <a asp-page="/Subjects/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Subjects") == true ? "active" : "")"><i class="fa-solid fa-book me-3"></i>Môn Học</a>
                }
                
                <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-2 text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">
                  <span>Lịch & Đánh giá</span>
                </h6>
                <a asp-page="/Timetables/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Timetables") == true ? "active" : "")"><i class="fa-solid fa-calendar-days me-3"></i>Thời Khóa Biểu</a>
                <a asp-page="/Grades/Index" class="list-group-item list-group-item-action bg-transparent rounded mb-1 text-secondary fw-semibold @(ViewContext.RouteData.Values["Page"]?.ToString()!.StartsWith("/Grades") == true ? "active" : "")"><i class="fa-solid fa-clipboard-check me-3"></i>Điểm / Kết Quả</a>
            </div>
        </div>
        <!-- /#sidebar-wrapper -->

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <!-- Top navigation -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3">
                <div class="container-fluid">
                    <button class="btn btn-light" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mt-2 mt-lg-0">
                            <li class="nav-item active"><a class="nav-link" href="#"><i class="fa-solid fa-bell"></i></a></li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-2" style="width:32px; height:32px;">
                                        @(User.Identity?.IsAuthenticated == true ? User.Identity.Name?.Substring(0, 1).ToUpper() : "A")
                                    </div>
                                    <span>@(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "Khách")</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
                                    <a class="dropdown-item" href="#!"><i class="fa-solid fa-user me-2"></i>Hồ sơ</a>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item text-danger" asp-page="/Account/Logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất</a>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <!-- Main Page Content -->
            <div class="container-fluid px-4 py-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
        <!-- /#page-content-wrapper -->
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Toggle Sidebar Script
        window.addEventListener('DOMContentLoaded', event => {
            const sidebarToggle = document.body.querySelector('#sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', event => {
                    event.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                    localStorage.setItem('sb|sidebar-toggle', document.body.classList.contains('sb-sidenav-toggled'));
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
