@page
@model SchoolManagement.Pages.Teacher.DashboardModel
@{
    ViewData["Title"] = "Trang chủ Giáo Viên";
}

<style>
    .stat-card { border:none; border-radius:0.75rem; transition: transform 0.2s ease, box-shadow 0.2s ease; box-shadow:0 0.15rem 1.75rem rgba(58,59,69,0.1); }
    .stat-card:hover { transform:translateY(-4px); box-shadow:0 0.5rem 2rem rgba(58,59,69,0.18); }
    .icon-circle { height:3.2rem; width:3.2rem; display:flex; align-items:center; justify-content:center; border-radius:50%; font-size:1.4rem; }
</style>

<!-- Welcome Banner -->
<div class="rounded-4 p-4 mb-5 text-white position-relative overflow-hidden"
     style="background: linear-gradient(135deg, #1b5e20, #388e3c); box-shadow:0 8px 32px rgba(46,125,50,0.3);">
    <h1 class="fw-bold mb-1" style="font-size:1.8rem;">Xin chào, @Model.TeacherFullName! 👋</h1>
    <p class="mb-0 opacity-75">Chào mừng bạn đến trang quản lý giảng dạy. Đây là tổng quan lớp học và lịch dạy của bạn hôm nay.</p>
    <i class="fa-solid fa-chalkboard-user position-absolute" style="right:-20px;bottom:-30px;font-size:10rem;opacity:0.08;"></i>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card stat-card h-100 py-2" style="border-left: 4px solid #2e7d32 !important;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-uppercase fw-bold text-success mb-1" style="font-size:0.75rem;">Lớp Chủ Nhiệm</div>
                    <div class="h2 fw-bold mb-1">@Model.MyClassCount</div>
                    <div class="text-muted small">Lớp bạn đang phụ trách</div>
                </div>
                <div class="icon-circle" style="background:rgba(46,125,50,0.12); color:#2e7d32;">
                    <i class="fa-solid fa-school"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card h-100 py-2" style="border-left: 4px solid #0277bd !important;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-uppercase fw-bold text-primary mb-1" style="font-size:0.75rem;">Học Sinh</div>
                    <div class="h2 fw-bold mb-1">@Model.MyStudentCount</div>
                    <div class="text-muted small">Học sinh trong lớp bạn</div>
                </div>
                <div class="icon-circle" style="background:rgba(2,119,189,0.1); color:#0277bd;">
                    <i class="fa-solid fa-user-graduate"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card h-100 py-2" style="border-left: 4px solid #f57f17 !important;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-uppercase fw-bold text-warning mb-1" style="font-size:0.75rem;">Tiết Dạy</div>
                    <div class="h2 fw-bold mb-1">@Model.MyTimetableCount</div>
                    <div class="text-muted small">Tiết dạy trong lịch</div>
                </div>
                <div class="icon-circle" style="background:rgba(245,127,23,0.1); color:#f57f17;">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Classes -->
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-bold border-bottom py-3">
                <i class="fa-solid fa-school me-2 text-success"></i>Lớp Chủ Nhiệm
            </div>
            <div class="card-body p-0">
                @if (Model.MyClasses.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var cls in Model.MyClasses)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">@cls.Name</span>
                                <span class="badge bg-success-subtle text-success border border-success-subtle">@cls.AcademicYear</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fa-solid fa-circle-info fa-2x mb-2 d-block"></i>
                        Chưa được phân công lớp chủ nhiệm.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Timetable Preview -->
    <div class="col-md-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-bold border-bottom py-3 d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-calendar-days me-2 text-success"></i>Lịch Dạy Của Tôi</span>
                <a asp-page="/Timetables/Index" class="btn btn-sm btn-outline-success">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                @if (Model.UpcomingTimetables.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Thứ</th>
                                    <th>Tiết</th>
                                    <th>Lớp</th>
                                    <th>Môn</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.UpcomingTimetables)
                                {
                                    <tr>
                                        <td class="fw-semibold text-success">Thứ @t.DayOfWeek</td>
                                        <td>Tiết @t.Period</td>
                                        <td>@t.Class?.Name</td>
                                        <td><span class="badge bg-info-subtle text-info border border-info-subtle">@t.Subject?.Name</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fa-solid fa-calendar-xmark fa-2x mb-2 d-block"></i>
                        Chưa có lịch dạy nào được phân công.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
